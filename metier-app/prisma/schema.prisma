generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model admin {
  admin_id   String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  username   String   @unique @db.VarChar(100)
  password   String
  created_at DateTime @default(now()) @db.Timestamp(6)
}

model blog {
  blog_id           String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  title             String         @db.VarChar(255)
  short_description String
  description       String
  slug              String         @unique @db.VarChar(255)
  thumbnail         String
  view_amount       Int            @default(0)
  status            blog_status    @default(UNPUBLISH)
  created_at        DateTime       @default(now()) @db.Timestamp(6)
  updated_at        DateTime       @default(now()) @db.Timestamp(6)
  blog_comment      blog_comment[]
  blog_picture      blog_picture[]

  @@index([slug], map: "idx_blog_slug")
  @@index([status], map: "idx_blog_status")
}

model blog_comment {
  blog_comment_id String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  blog_id         String         @db.Uuid
  username        String         @db.VarChar(100)
  comment         String
  status          comment_status @default(PENDING)
  created_at      DateTime       @default(now()) @db.Timestamp(6)
  blog            blog           @relation(fields: [blog_id], references: [blog_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_blog_comment_blog")

  @@index([blog_id], map: "idx_blog_comment_blog_id")
  @@index([status], map: "idx_blog_comment_status")
}

model blog_picture {
  blog_picture_id String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  blog_id         String   @db.Uuid
  image_url       String
  created_at      DateTime @default(now()) @db.Timestamp(6)
  blog            blog     @relation(fields: [blog_id], references: [blog_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_blog_picture_blog")

  @@index([blog_id], map: "idx_blog_picture_blog_id")
}

enum blog_status {
  PUBLISH
  UNPUBLISH
}

enum comment_status {
  PENDING
  APPROVED
  REJECTED
}
